# Database
DATABASE_URL=

# Auth.js
AUTH_SECRET=
# Required when self-hosting behind a reverse proxy (Traefik/Coolify) — trusts
# X-Forwarded-Host/Proto so Auth.js can detect the correct callback URL.
# See https://authjs.dev/getting-started/deployment
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Owner
OWNER_EMAIL=
