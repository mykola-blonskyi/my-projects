# Database
DATABASE_URL=postgresql://user:password@localhost:5432/hub

# Auth.js v5
# Generate with: openssl rand -base64 32
# Must be the same across hub and all subdomain apps
AUTH_SECRET=your-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Owner access control (controls who gets admin access — not a DB flag)
OWNER_EMAIL=your-google-email@gmail.com

# API URL (hub doubles as the API for subdomain auth)
API_URL=https://blonskyi.dev
