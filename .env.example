# Database
# Composed into DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@postgres:5432/DB_NAME by docker-compose.yml
# If DB_PASSWORD contains @ : / % or other URL-reserved characters, URL-encode it here.
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth.js
AUTH_SECRET=
# Required when self-hosting behind a reverse proxy (Traefik/Coolify) — trusts
# X-Forwarded-Host/Proto so Auth.js can detect the correct callback URL.
# See https://authjs.dev/getting-started/deployment
AUTH_TRUST_HOST=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Owner
OWNER_EMAIL=
